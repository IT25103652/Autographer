# =================================
# AI Photo Studio - Environment Variables
# =================================
# Copy this file to .env.local for local development
# DO NOT commit actual .env.local with real credentials

# =================================
# Appwrite Configuration (Backend)
# =================================
# Get these from https://cloud.appwrite.io/
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_APPWRITE_DATABASE_ID=ai_photo_studio
NEXT_PUBLIC_APPWRITE_STORAGE_BUCKET_ID=ai-images
APPWRITE_API_KEY=your_api_key_here

# =================================
# Sentry Configuration (Error Monitoring)
# =================================
# Get your DSN from https://sentry.io/
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# =================================
# Application Configuration
# =================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Autographer AI Photo Studio

# =================================
# AI Model Providers (Optional)
# =================================
# Replicate API Key (for AI image generation)
REPLICATE_API_TOKEN=your_replicate_token_here

# Stability AI API Key (alternative AI provider)
STABILITY_API_KEY=your_stability_key_here

# OpenAI API Key (for GPT-based features)
OPENAI_API_KEY=your_openai_key_here

# =================================
# Payment Gateways
# =================================
# Stripe Secret Key (for credit purchases)
STRIPE_SECRET_KEY=sk_test_your_stripe_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# PayHere Configuration (Sri Lanka payment gateway)
PAYHERE_MERCHANT_ID=your_merchant_id
PAYHERE_SECRET_KEY=your_payhere_secret

# =================================
# Email Service (Optional)
# =================================
# SendGrid API Key for transactional emails
SENDGRID_API_KEY=your_sendgrid_key

# =================================
# Production Deployment
# =================================
# Set to 'production' when deploying to production
NODE_ENV=development

# =================================
# Feature Flags
# =================================
# Enable/disable features without code changes
NEXT_PUBLIC_ENABLE_REFERRALS=true
NEXT_PUBLIC_ENABLE_MARKETPLACE=true
NEXT_PUBLIC_ENABLE_PHOTOGRAPHERS=true
